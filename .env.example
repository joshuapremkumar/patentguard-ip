# PatentGuard IP — Environment Variables Template
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# TinyFish Web Automation API
TINYFISH_API_KEY=your_tinyfish_api_key_here
TINYFISH_WORKFLOW_ID=your_workflow_id_here
TINYFISH_BASE_URL=https://api.tinyfish.io

# Backend URL (used by Streamlit frontend)
# For local dev: http://localhost:8080
# For Docker Compose: http://backend:8080
BACKEND_URL=http://localhost:8080
